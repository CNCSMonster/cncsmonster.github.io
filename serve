#!/bin/bash
# 启动/停止 Zola 博客本地预览
# 用法:
#   ./serve              启动服务（默认端口 1111）
#   ./serve [端口]       启动服务（指定端口）
#   ./serve --status     检查启动状态
#   ./serve stop         停止服务

set -e

DEFAULT_PORT=1111
LOG_FILE="/tmp/zola-serve.log"
MATCH_PATTERN="zola serve"

cd "$(dirname "$0")"

# ── status 子命令 ──
if [ "$1" = "--status" ]; then
    PID=$(pgrep -f "$MATCH_PATTERN" | head -1)
    if [ -z "$PID" ]; then
        echo "❌ Zola 博客未运行"
        echo "   启动: ./serve"
        exit 1
    fi
    PORT=$(ss -tlnp 2>/dev/null | grep "pid=$PID" | awk '{print $4}' | grep -oP ':\K\d+' | head -1)
    PORT=${PORT:-$DEFAULT_PORT}
    HTTP=$(curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:$PORT/" 2>/dev/null || echo "000")
    echo "📝 Zola 博客"
    echo "   PID:  $PID"
    echo "   URL:  http://localhost:$PORT"
    echo "   HTTP: $HTTP"
    if [ "$HTTP" = "200" ]; then
        echo "   状态: ✅ 运行中"
    else
        echo "   状态: ⚠️  服务未就绪 (HTTP $HTTP)"
    fi
    exit 0
fi

# ── stop 子命令 ──
if [ "$1" = "stop" ]; then
    pkill -f "$MATCH_PATTERN" 2>/dev/null && echo "✅ Zola 博客已停止" || echo "⚠️  没有运行中的 Zola 博客"
    exit 0
fi

# ── 启动服务 ──
PORT="${1:-$DEFAULT_PORT}"

# 校验端口
if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
    echo "❌ 无效端口: $PORT (需要 1-65535 的数字)"
    exit 1
fi

# 杀旧进程
pkill -f "$MATCH_PATTERN" 2>/dev/null && sleep 1 || true

# 后台启动
nohup zola serve --port "$PORT" > "$LOG_FILE" 2>&1 &
PID=$!
disown $PID

# 等待启动
for i in $(seq 1 10); do
    kill -0 "$PID" 2>/dev/null || { echo "❌ 进程 $PID 已退出"; tail -5 "$LOG_FILE" 2>/dev/null; exit 1; }
    sleep 1
    ACTUAL_PORT=$(ss -tlnp 2>/dev/null | grep "pid=$PID" | grep -oP ':\d+' | head -1 | tr -d ':')
    [ -n "$ACTUAL_PORT" ] && break
done

if [ -z "$ACTUAL_PORT" ]; then
    echo "❌ Zola 未能启动 (PID $PID 已退出?)"
    echo "   日志: $LOG_FILE"
    exit 1
fi

# 验证
HTTP=$(curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:$ACTUAL_PORT/" 2>/dev/null)

echo ""
if [ "$HTTP" = "200" ]; then
    echo "✅ Zola 博客: http://localhost:$ACTUAL_PORT"
    echo "   停止: ./serve stop"
else
    echo "⚠️  端口 $ACTUAL_PORT 返回 HTTP $HTTP"
    echo "   zola 可能还在启动中，稍等重试"
    echo "   日志: $LOG_FILE"
fi
